{
  "name": "@logigator/sim",
  "version": "0.1.2",
  "description": "Logigator simulation engine: native Node.js addon, browser WASM build, and the sim CLI.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logigator/logigator-sim.git"
  },
  "type": "module",
  "engines": {
    "node": ">= 20"
  },
  "bin": {
    "logigator-sim": "bin/sim.js"
  },
  "exports": {
    "./node": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./wasm": {
      "types": "./wasm/sim_wasm.d.ts",
      "default": "./wasm/sim_wasm.js"
    },
    "./wasm/sim_wasm_bg.wasm": "./wasm/sim_wasm_bg.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "bin/",
    "wasm/"
  ],
  "napi": {
    "binaryName": "sim-node",
    "packageName": "@logigator/sim",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "napi build --platform --esm --profile release-addon",
    "build:debug": "napi build --platform --esm",
    "prepublishOnly": "napi pre-publish -t npm --no-gh-release",
    "test": "node --test __test__/*.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "optionalDependencies": {
    "@logigator/sim-linux-x64-gnu": "0.1.2",
    "@logigator/sim-linux-x64-musl": "0.1.2",
    "@logigator/sim-linux-arm64-gnu": "0.1.2",
    "@logigator/sim-darwin-x64": "0.1.2",
    "@logigator/sim-darwin-arm64": "0.1.2",
    "@logigator/sim-win32-x64-msvc": "0.1.2"
  }
}
