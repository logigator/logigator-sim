{
  "name": "@logigator/sim-node",
  "version": "0.1.0",
  "description": "Node.js native addon for the Logigator simulation engine (plan §7.4).",
  "license": "MIT",
  "repository": "https://github.com/logigator/logigator-sim",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">= 18"
  },
  "napi": {
    "binaryName": "sim-node",
    "packageName": "@logigator/sim-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test __test__/"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
